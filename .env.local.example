# ============================================
# Justin's Personal Page — Live Data Endpoints
# ============================================
# Copy this file to `.env.local` and fill in the URLs to your
# homelab services. If a variable is unset, the UI shows a "Demo"
# indicator instead of live numbers.

# ADS-B (tar1090 / readsb / dump1090)
# Should return a JSON payload containing an `aircraft` array.
# Example for a local tar1090 instance:
#   http://tar1090.lan/data/aircraft.json
ADSB_ENDPOINT=

# Optional: Your receiver's coordinates to calculate the max range
# if your ADS-B software doesn't provide the `dst` field automatically.
RECEIVER_LAT=
RECEIVER_LON=

# BirdNET-Go
# Base URL of your BirdNET-Go instance (without trailing slash).
# The API proxy hits /api/v2/analytics/species/summary internally.
# Example:
#   http://birdnet.lan:8080
BIRDNET_ENDPOINT=

# Steam API (for recently played games)
# Get an API key from: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=
# Your 17-digit SteamID64 (you can find this via steamid.io)
STEAM_ID=

# Uptime Kuma (for homelab service status)
# Base URL of your Uptime Kuma instance
# Example: https://status.example.com
UPTIME_KUMA_ENDPOINT=
# The slug of your public status page (often "default")
UPTIME_KUMA_SLUG=default
